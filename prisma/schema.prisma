generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  PLATFORM_ADMIN
  TENANT_ADMIN
  DISPATCHER
  WAREHOUSE
  CUSTOMER_SERVICE
  CARRIER_ADMIN
  CARRIER_DISPATCHER
  DRIVER
}

enum ShipmentStatus {
  DRAFT
  READY_FOR_BOL
  BOL_CREATED
  ROUTED
  PUBLISHED
  IN_TRANSIT
  DELIVERED
  EXCEPTION
  CANCELLED
}

enum RouteStatus {
  DRAFT
  PUBLISHED
  IN_TRANSIT
  COMPLETED
}

enum RouteStopStatus {
  PLANNED
  PUBLISHED
  IN_TRANSIT
  DELIVERED
  REFUSED
  RETURNED
  EXCEPTION
}

enum DeliveryEventType {
  IN_TRANSIT
  DELIVERED
  PAYMENT_COLLECTED
  RETURNED
  REFUSED
  EXCEPTION
}

enum LabelKind {
  CARTON
  PALLET
}

enum DocumentKind {
  PACKING_SLIP
  BOL
  ROUTE_SHEET
  CARTON_LABEL
  PALLET_LABEL
  POD_PHOTO
  POD_SIGNATURE
}

enum IssueReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum OutboundEmailStatus {
  PENDING
  SENT
  FAILED
}

enum MobileAlertStatus {
  PENDING
  SENT
  FAILED
  ACKNOWLEDGED
}

enum RouteAssignmentStatus {
  OFFERED
  ACCEPTED
  DECLINED
  DRIVER_ASSIGNED
  IN_TRANSIT
  COMPLETED
  EXCEPTION
  CANCELLED
  REASSIGNED
}

enum DriverDevicePlatform {
  IOS
  ANDROID
  WEB
}

enum TenantBillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  CANCELED
  PAUSED
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

enum TenantAccessState {
  ACTIVE
  LOCKED
}

model Tenant {
  id                  String             @id @default(cuid())
  slug                String             @unique
  name                String
  billingEmail        String?
  trialStartedAt      DateTime?
  trialEndsAt         DateTime?
  billingStatus       TenantBillingStatus @default(TRIALING)
  accessState         TenantAccessState   @default(ACTIVE)
  billingLockedAt     DateTime?
  billingLockReason   String?
  stripeCustomerId    String?             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId       String?
  billingCurrentPeriodEnd DateTime?
  billingCheckoutCompletedAt DateTime?
  gs1CompanyPrefix    String?
  warehouseName       String?
  warehouseAddress1   String?
  warehouseAddress2   String?
  warehouseCity       String?
  warehouseState      String?
  warehousePostalCode String?
  warehouseCountry    String?            @default("US")
  warehousePhone      String?
  warehouseFob        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  memberships         TenantMembership[]
  customers           Customer[]
  locations           CustomerLocation[]
  carriers            Carrier[]
  drivers             Driver[]
  salesReps           SalesRep[]
  products            Product[]
  shipments           Shipment[]
  shipmentLines       ShipmentLine[]
  bills               BillOfLading[]
  routes              RouteRun[]
  routeStops          RouteStop[]
  labels              LabelJob[]
  documents           Document[]
  deliveryEvents      DeliveryEvent[]
  issueReports        IssueReport[]
  outboundEmails      OutboundEmail[]
  mobileAlerts        MobileAlert[]
  routeAssignments    RouteAssignment[]
  driverDevices       DriverDevice[]
  driverLocationPings DriverLocationPing[]
  auditLogs           AuditLog[]
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  fullName       String
  passwordHash   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  memberships    TenantMembership[]
  createdRoutes  RouteRun[]         @relation("RouteCreatedBy")
  issueReports   IssueReport[]
  outboundEmails OutboundEmail[]
  routeAssignmentsCreated   RouteAssignment[] @relation("RouteAssignmentCreatedBy")
  routeAssignmentsResponded RouteAssignment[] @relation("RouteAssignmentRespondedBy")
  passwordResetTokens PasswordResetToken[]
  auditLogs      AuditLog[]
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TenantMembership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole
  carrierId String?
  driverId  String?
  isPortalAccess Boolean   @default(false)
  createdAt DateTime       @default(now())
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  carrier   Carrier?       @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  driver    Driver?        @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@index([carrierId])
  @@index([driverId])
}

model Customer {
  id              String             @id @default(cuid())
  tenantId        String
  customerCode    String
  name            String
  billingAddress1 String?
  billingAddress2 String?
  city            String?
  state           String?
  postalCode      String?
  country         String?            @default("US")
  phone           String?
  email           String?
  comments        String?
  shipCode        String?
  shipName        String?
  shipAddress1    String?
  shipAddress2    String?
  shipCity        String?
  shipState       String?
  shipPostalCode  String?
  shipCountry     String?            @default("US")
  shipPhone       String?
  shipEmail       String?
  freightTerms    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locations       CustomerLocation[]
  shipments       Shipment[]

  @@unique([tenantId, customerCode])
}

model CustomerLocation {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  code       String?
  name       String
  address1   String
  address2   String?
  city       String
  state      String
  postalCode String
  country    String   @default("US")
  phone      String?
  email      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
}

model Carrier {
  id            String     @id @default(cuid())
  tenantId      String
  carrierCode   String
  name          String
  address1      String?
  address2      String?
  city          String?
  state         String?
  postalCode    String?
  country       String?    @default("US")
  scac          String?
  email         String?
  phone         String?
  fax           String?
  cell          String?
  contactName   String?
  website       String?
  websitePickup String?
  isLtl         Boolean    @default(false)
  isFtl         Boolean    @default(false)
  isBroker      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  drivers       Driver[]
  portalUsers   TenantMembership[]
  shipments     Shipment[]
  routes        RouteRun[]
  assignments   RouteAssignment[]

  @@unique([tenantId, carrierCode])
}

model SalesRep {
  id        String   @id @default(cuid())
  tenantId  String
  repCode   String
  fullName  String
  email     String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, repCode])
}

model Driver {
  id             String          @id @default(cuid())
  tenantId       String
  carrierId      String?
  driverCode     String
  fullName       String
  phone          String?
  email          String?
  mobileToken    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  carrier        Carrier?        @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  routes         RouteRun[]
  deliveryEvents DeliveryEvent[]
  mobileAlerts   MobileAlert[]
  portalUsers    TenantMembership[]
  assignments    RouteAssignment[]
  devices        DriverDevice[]
  locationPings  DriverLocationPing[]

  @@unique([tenantId, driverCode])
}

model Product {
  id              String         @id @default(cuid())
  tenantId        String
  sku             String
  description     String
  productLine     String?
  productType     String?
  packageType     String?
  nmfcCode        String?
  defaultWeightLb Float?
  lengthIn        Float?
  widthIn         Float?
  heightIn        Float?
  casePack        String?
  volumeCuFt      Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipmentLines   ShipmentLine[]

  @@unique([tenantId, sku])
}

model Shipment {
  id             String          @id @default(cuid())
  tenantId       String
  customerId     String
  carrierId      String?
  batchId        String
  customerPo     String?
  salesOrder     String?
  salesperson    String?
  status         ShipmentStatus  @default(DRAFT)
  legacyStatusLabel String?
  routedDate     DateTime?
  shipDate       DateTime?
  cancelDate     DateTime?
  deliveryDate   DateTime?
  deliveryWindow String?
  routeDeskDate  DateTime?
  authorization  String?
  approvedBy     String?
  approvalNotes  String?
  scac           String?
  checkOrCash    String?
  comments       String?
  codAmount      Float?
  units          Int             @default(0)
  cartons        Int             @default(0)
  pallets        Int             @default(0)
  weightLb       Float           @default(0)
  cubeCuFt       Float           @default(0)
  heightIn       Float?
  freightClass   String?
  emailSubject   String?
  rfqSubject     String?
  department     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  carrier        Carrier?        @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  lines          ShipmentLine[]
  bol            BillOfLading?
  labelJobs      LabelJob[]
  routeStops     RouteStop[]
  deliveryEvents DeliveryEvent[]

  @@unique([tenantId, batchId])
  @@index([tenantId, status])
}

model ShipmentLine {
  id          String   @id @default(cuid())
  tenantId    String
  shipmentId  String
  productId   String?
  itemCode    String
  description String?
  cartons     Int      @default(0)
  pallets     Int      @default(0)
  weightLb    Float?
  lengthIn    Float?
  widthIn     Float?
  heightIn    Float?
  casePack    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, shipmentId])
}

model BillOfLading {
  id              String    @id @default(cuid())
  tenantId        String
  shipmentId      String    @unique
  bolNumber       String
  templateVariant String    @default("STANDARD")
  freightTerms    String?
  carrierName     String?
  trailerNumber   String?
  sealNumber      String?
  printedAt       DateTime?
  emailedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment        Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, bolNumber])
}

model RouteRun {
  id             String          @id @default(cuid())
  tenantId       String
  carrierId      String?
  driverId       String?
  createdById    String?
  routeDate      DateTime
  routeName      String
  truckCount     Int             @default(1)
  status         RouteStatus     @default(DRAFT)
  publishedAt    DateTime?
  mobileSyncAt   DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  carrier        Carrier?        @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  driver         Driver?         @relation(fields: [driverId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("RouteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  stops          RouteStop[]
  assignments    RouteAssignment[]
  outboundEmails OutboundEmail[]
  mobileAlerts   MobileAlert[]

  @@index([tenantId, routeDate])
}

model RouteStop {
  id             String          @id @default(cuid())
  tenantId       String
  routeRunId     String
  shipmentId     String
  stopNumber     Int
  status         RouteStopStatus @default(PLANNED)
  plannedStart   DateTime?
  plannedEnd     DateTime?
  deliveredAt    DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  routeRun       RouteRun        @relation(fields: [routeRunId], references: [id], onDelete: Cascade)
  shipment       Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Restrict)
  deliveryEvents DeliveryEvent[]

  @@unique([routeRunId, stopNumber])
  @@index([tenantId, shipmentId])
}

model DeliveryEvent {
  id                String            @id @default(cuid())
  tenantId          String
  shipmentId        String
  routeStopId       String?
  routeAssignmentId String?
  driverId          String?
  eventType         DeliveryEventType
  eventAt           DateTime          @default(now())
  recipientName     String?
  note              String?
  codAmount         Float?
  paymentType       String?
  proofPhotoUrl     String?
  proofSignatureUrl String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment          Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  routeStop         RouteStop?        @relation(fields: [routeStopId], references: [id], onDelete: SetNull)
  routeAssignment   RouteAssignment?  @relation(fields: [routeAssignmentId], references: [id], onDelete: SetNull)
  driver            Driver?           @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([tenantId, shipmentId])
  @@index([tenantId, eventType, eventAt])
}

model LabelJob {
  id              String    @id @default(cuid())
  tenantId        String
  shipmentId      String?
  labelKind       LabelKind
  templateVariant String    @default("SIMPLE")
  quantity        Int       @default(1)
  printedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment        Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, labelKind])
}

model Document {
  id         String       @id @default(cuid())
  tenantId   String
  shipmentId String?
  routeRunId String?
  kind       DocumentKind
  fileName   String
  storageKey String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, kind])
}

model IssueReport {
  id         String            @id @default(cuid())
  tenantId   String
  userId     String?
  pagePath   String?
  title      String
  details    String
  status     IssueReportStatus @default(OPEN)
  adminNotes String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
}

model OutboundEmail {
  id           String              @id @default(cuid())
  tenantId     String
  userId       String?
  routeRunId   String?
  toEmail      String
  subject      String
  htmlBody     String
  status       OutboundEmailStatus @default(PENDING)
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  routeRun     RouteRun?           @relation(fields: [routeRunId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
}

model MobileAlert {
  id             String            @id @default(cuid())
  tenantId       String
  routeRunId     String
  driverId       String
  routeAssignmentId String?
  title          String
  body           String
  payloadJson    String?
  status         MobileAlertStatus @default(PENDING)
  errorMessage   String?
  sentAt         DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  routeRun       RouteRun          @relation(fields: [routeRunId], references: [id], onDelete: Cascade)
  driver         Driver            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  routeAssignment RouteAssignment? @relation(fields: [routeAssignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([driverId, status, createdAt])
}

model RouteAssignment {
  id                String                @id @default(cuid())
  tenantId          String
  routeRunId        String
  carrierId         String
  driverId          String?
  assignedByUserId  String?
  respondedByUserId String?
  trackingNumber    String
  status            RouteAssignmentStatus @default(OFFERED)
  offeredAt         DateTime              @default(now())
  acceptedAt        DateTime?
  declinedAt        DateTime?
  driverAssignedAt  DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  lastLocationAt    DateTime?
  declineReason     String?
  notes             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  routeRun          RouteRun              @relation(fields: [routeRunId], references: [id], onDelete: Cascade)
  carrier           Carrier               @relation(fields: [carrierId], references: [id], onDelete: Restrict)
  driver            Driver?               @relation(fields: [driverId], references: [id], onDelete: SetNull)
  assignedBy        User?                 @relation("RouteAssignmentCreatedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  respondedBy       User?                 @relation("RouteAssignmentRespondedBy", fields: [respondedByUserId], references: [id], onDelete: SetNull)
  mobileAlerts      MobileAlert[]
  locationPings     DriverLocationPing[]
  deliveryEvents    DeliveryEvent[]

  @@unique([tenantId, trackingNumber])
  @@index([tenantId, status, offeredAt])
  @@index([routeRunId, status])
  @@index([carrierId, status])
  @@index([driverId, status])
}

model DriverDevice {
  id          String               @id @default(cuid())
  tenantId    String
  driverId    String
  deviceLabel String?
  platform    DriverDevicePlatform @default(ANDROID)
  pushToken   String
  appVersion  String?
  lastSeenAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  driver      Driver               @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([tenantId, driverId])
  @@unique([driverId, pushToken])
}

model DriverLocationPing {
  id                String          @id @default(cuid())
  tenantId          String
  routeAssignmentId String
  driverId          String
  latitude          Float
  longitude         Float
  accuracyMeters    Float?
  speedMph          Float?
  headingDegrees    Float?
  batteryLevel      Float?
  capturedAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  routeAssignment   RouteAssignment @relation(fields: [routeAssignmentId], references: [id], onDelete: Cascade)
  driver            Driver          @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([tenantId, capturedAt])
  @@index([routeAssignmentId, capturedAt])
  @@index([driverId, capturedAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  entityType  String
  entityId    String
  action      String
  payloadJson String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId])
}
